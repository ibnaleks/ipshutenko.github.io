\t\t\t<div class=\"elementor-element elementor-element-59740cf elementor-widget elementor-widget-heading\" data-id=\"59740cf\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">\u041c\u044b <br>\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u0443\u0435\u043c:<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-71f7907 e-con-full e-flex e-con e-child\" data-id=\"71f7907\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-7f2c10f elementor-widget elementor-widget-text-editor\" data-id=\"7f2c10f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p><strong>\u042d\u043b\u0435\u043a\u0442\u0440\u043e\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b:<\/strong> \u043f\u0435\u0440\u0444\u043e\u0440\u0430\u0442\u043e\u0440\u044b, \u043e\u0442\u0431\u043e\u0439\u043d\u044b\u0435 \u043c\u043e\u043b\u043e\u0442\u043a\u0438, \u0431\u043e\u043b\u0433\u0430\u0440\u043a\u0438 (\u0443\u0448\u043c), \u0434\u0440\u0435\u043b\u0438, \u0448\u0443\u0440\u0443\u043f\u043e\u0432\u0435\u0440\u0442\u044b, \u043f\u0438\u043b\u044b, \u043b\u043e\u0431\u0437\u0438\u043a\u0438.<br \/><strong>\u0411\u0435\u043d\u0437\u043e\u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b:<\/strong> \u0433\u0435\u043d\u0435\u0440\u0430\u0442\u043e\u0440\u044b, \u043c\u043e\u0442\u043e\u043f\u043e\u043c\u043f\u044b, \u0431\u0435\u043d\u0437\u043e\u043f\u0438\u043b\u044b, \u043c\u043e\u0442\u043e\u0431\u0443\u0440\u044b.<br \/><strong>\u0421\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u0435:<\/strong> \u0431\u0435\u0442\u043e\u043d\u043e\u0441\u043c\u0435\u0441\u0438\u0442\u0435\u043b\u0438, \u0432\u0438\u0431\u0440\u043e\u0442\u0440\u0430\u043c\u0431\u043e\u0432\u043a\u0438, \u0432\u0438\u0431\u0440\u043e\u043d\u043e\u0433\u0438, \u0431\u0435\u043d\u0437\u043e\u0440\u0435\u0437\u0447\u0438\u043a\u0438.<br \/><strong>\u041a\u043e\u043c\u043f\u0440\u0435\u0441\u0441\u043e\u0440\u044b:<\/strong> \u043f\u043e\u0440\u0448\u043d\u0435\u0432\u044b\u0435, \u0431\u0435\u0437\u043c\u0430\u0441\u043b\u044f\u043d\u044b\u0435, \u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0435.<br \/><strong>\u0421\u0430\u0434\u043e\u0432\u0443\u044e \u0442\u0435\u0445\u043d\u0438\u043a\u0443:<\/strong> \u043a\u0443\u043b\u044c\u0442\u0438\u0432\u0430\u0442\u043e\u0440\u044b, \u0433\u0430\u0437\u043e\u043d\u043e\u043a\u043e\u0441\u0438\u043b\u043a\u0438, \u0432\u0435\u0442\u0440\u043e\u0434\u0443\u0432\u044b, \u0441\u043d\u0435\u0433\u043e\u0443\u0431\u043e\u0440\u0449\u0438\u043a\u0438.<br \/><strong>\u0422\u0435\u043f\u043b\u043e\u0432\u044b\u0435 \u043f\u0443\u0448\u043a\u0438:<\/strong> \u0433\u0430\u0437\u043e\u0432\u044b\u0435, \u0434\u0438\u0437\u0435\u043b\u044c\u043d\u044b\u0435, \u044d\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u043a\u0438\u0435.<br \/><strong>\u0414\u0432\u0438\u0433\u0430\u0442\u0435\u043b\u0438:<\/strong> \u0434\u0432\u0443\u0445\u0442\u0430\u043a\u0442\u043d\u044b\u0435, \u0447\u0435\u0442\u044b\u0440\u0435\u0445\u0442\u0430\u043a\u0442\u043d\u044b\u0435.<br \/><strong>\u0421\u0442\u0430\u043d\u043a\u0438:<\/strong> \u0441\u0432\u0435\u0440\u043b\u0438\u043b\u044c\u043d\u044b\u0435, \u043e\u0442\u0440\u0435\u0437\u043d\u044b\u0435, \u0434\u0435\u0440\u0435\u0432\u043e\u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0435, \u0437\u0430\u0442\u043e\u0447\u043d\u044b\u0435, \u0440\u0435\u0439\u0441\u043c\u0443\u0441\u043d\u043e-\u0444\u0443\u0433\u043e\u0432\u0430\u043b\u044c\u043d\u044b\u0435.<\/p><p><strong style=\"font-style: inherit; text-align: center;\">\u0438 \u043c\u043d\u043e\u0433\u043e\u0435-\u043c\u043d\u043e\u0433\u043e\u0435 